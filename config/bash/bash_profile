# ~/.bash_profile: executed by bash(1) for login shells.
# see /usr/share/doc/bash/examples/startup-files (in the package bash-doc)
# for examples

# For login shells, when ~/.bash_profile exists, only ~/.bash_profile is
# automatically executed, even if login shell is also interactive.

# For non-login, interactive shells, .bashrc is run, if it exists.

# Determine how this shell was invoked
recent="$(ps --pid=$PPID -ocmd | tail -1)"

# When invoked by SSHD or by sudo -i, run .bashrc
if [ "x${recent:0:4}" == xsshd ] || [ "x${recent:0:7}" == "xsudo -i" ] ; then
    if [ -f ~/.bashrc ]; then source ~/.bashrc; fi
fi
unset recent

