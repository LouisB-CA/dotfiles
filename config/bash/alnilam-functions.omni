# ~/.functions
# ~/.bash_function

# Notes:
#	1. the use of keyword "function" is deprecated for POSIX portability
#	2. some of these functions are exported (to subshells) but other are not.
#		when exporting function names, define the function first, then `export -f` the name
#

unset -f lochowto ; unalias lochowto 2> /dev/null
lochowto () {

	[ $# == 0 ] || lc 'how.to|usernote|llm.chat' | grep -i $*

}
# do not export -f lochowto


#
# see HOW-TO_Install_Anaconda_3.txt
# usage:	cprep							## without an arugment, activates conda base environment
# 			conda activate pyspice			## activates PySpice environment
# 			conda deactivate				## deactivates the conda environment
#
# This command-line function prepares the bash environment for conda activation.
# The code in this function was originally inserted into .bashrc by the "conda init" command, but
# it should not be executed in every bash shell.
# The function name 'cprep' is short for "conda prepare"
unset -f cprep ; unalias cprep 2> /dev/null
cprep() {
	__conda_setup="$('/opt/anaconda3/bin/conda' 'shell.bash' 'hook' 2> /dev/null)"
	if [ $? -eq 0 ]; then
    	eval "$__conda_setup"
	else
    	if [ -f "/opt/anaconda3/etc/profile.d/conda.sh" ]; then
        	. "/opt/anaconda3/etc/profile.d/conda.sh"
    	else
        	export PATH="/opt/anaconda3/bin:$PATH"
    	fi
	fi
	unset __conda_setup
}
export -f cprep

unset -f reconnect ; unalias reconnect 2> /dev/null
reconnect() {
    # reconnect nordvpn to the same server
    local SERVER="$( nordvpn status | grep 'Hostname: ' | sed 's/^.*: \(.*\)\.nordvpn\.com/\1/' )"
    /usr/bin/nordvpn connect ${SERVER:-San_Francisco} || /usr/bin/nordvpn connect San_Francisco
    /usr/bin/nordvpn status
}


