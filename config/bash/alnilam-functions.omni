# ~/.functions
# ~/.bash_function

# Notes:
#	1. the use of keyword "function" is deprecated for POSIX portability
#	2. some of these functions are exported (to subshells) but other are not.
#		when exporting function names, define the function first, then `export -f` the name
#

unset -f wolframscript ; unalias wolframscript 2> /dev/null
wolframscript () {

  local IMAGE="my-wolfram-14-image"
  local CNAME="wolfboy14"
  local CHOSTNAME="wolfboy"

  # Get a disposable container running with my version of the WRI image
  docker run --name "$CNAME" --hostname $CHOSTNAME --privileged --rm \
         -v ~/prgms/WolframEngine:/home/louis/WolframEngine \
         -v ~/prgms/WolframScript:/home/louis/WolframScript \
         -v ~/.WolframEngine:/home/louis/.WolframEngine \
         -v ~/.cache/Wolfram:/home/louis/.cache/Wolfram \
         -v ~/.config/Wolfram:/home/louis/.config/Wolfram \
         --user $USER -it "$IMAGE" \
         wolframscript "$@"

}
export wolframscript


unset -f wolfboy ; unalias wolfboy 2> /dev/null
wolfboy() {
    local IMAGE="my-wolfram-14-image"
    local CNAME="wolfboy14"
    local CHOSTNAME="wolfboy"
    # If not running, start container in background (sleep infinity)
    if docker ps --format '{{.Names}}' | grep -q "^${CNAME}$"; then
        docker start "$CNAME" && \
          docker exec -it "$CNAME" bash
          #docker exec --user root --workdir /root -it "$CNAME" bash
    else
        #docker run  --rm --privileged --user root --workdir /root \
        docker run  --rm --privileged \
                    --name "$CNAME" -it "$IMAGE" bash
    fi
}

export wolfboy

unset -f ll ; unalias ll 2> /dev/null
ll() {
	## this is like the alias "la" piped through less
	/bin/ls -lAX --color=auto $* | less
}

unset -f lochowto ; unalias lochowto 2> /dev/null
lochowto () {

	[ $# == 0 ] || lc 'how.to|usernote|llm.chat' | grep -i $*

}

unset -f df ; unalias df 2> /dev/null
df () {

	## <!-- https://stackoverflow.com/a/56151840/5937262 -->
	/bin/df -h $* | (sed -u 1q; grep -v loop | sort)

}

unset -f rvbfunc ; unalias rvbfunc 2> /dev/null
rvbfunc () {
	# check that exactly 1 argument was given
	if [ $# != 1 ] ; then		# expect exactly one argument
		echo "Usage:  rvbfunc  video-file-name"
		return
	fi

	# check that the argument expands into exactly one file or directory name
	local FNAME=$(/bin/ls "$1")
	echo "$FNAME"
	if [ $(echo $FNAME | wc -l) != 1 ] ; then
		echo "Usage:  $1  video-file-name"
		return
	fi

	# check that the name is a file and is readable
	if [ -f "$FNAME" ] && [ -r "$FNAME" ] ; then
		local PREFIX="${FNAME%.*}"
		local EXTENSION="${FNAME#$PREFIX}"
	else
		echo "$0: cannot find/read file $1"
		return
	fi
	echo "$1"
	## echo $PREFIX
	## echo $EXTENSION

	if [ "x$EXTENSION" == x.mp4 ] ; then	# expect any extension except .mp4
		echo "cannot convert MP4 file to MP4"
		return
	fi
	
	# create output file name and run ffmpeg at about 60% cpu, to prevent cpu overheating
    local OUTFILE=$(basename "$PREFIX").mp4;
	## echo $OUTFILE
    cpulimit -l 60 -- ffmpeg -i "$1" -c:v libx265 -crf 28 -c:a copy -y "$OUTFILE"
}

unset -f cd ; unalias cd 2> /dev/null
function cd () { 
	# https://superuser.com/questions/299694/is-there-a-directory-history-for-bash
	# Usage:    cd --    (list current history)
	#           cd -num  (go to num directory)
	#           cd -     (go to previous directory)
    local hnum=16;
    local new_dir index dir cnt;
    if ! [ $# -eq 0 ]; then
        if [[ $# -eq 2 && $1 = "--" ]]; then
            shift;
        else
            if ! { 
                [ $# -eq 1 ] && [[ $1 =~ ^(-[0-9]{,2}|-|--|[^-].*)$ ]]
            }; then
                builtin cd "$@";
                return;
            fi;
        fi;
    fi;
    [ "$1" = "--" ] && { 
        dirs -v;
        return
    };
    new_dir=${1:-$HOME};
    if [[ "$new_dir" =~ ^-[0-9]{,2}$ ]]; then
        index=${new_dir:1};
        if [ -z "$index" ]; then
            new_dir=$OLDPWD;
        else
            new_dir=$(dirs -l +$index) || return;
        fi;
    fi;
    pushd -- "$new_dir" > /dev/null || return;
    popd -n +$hnum &> /dev/null || true;
    new_dir=$PWD cnt=1;
    while dir=$(dirs -l +$cnt 2> /dev/null); do
        if [ "$dir" = "$new_dir" ]; then
            popd -n +$cnt > /dev/null;
            continue;
        fi;
        let cnt++;
    done
}

unset -f ffnorm ; unalias ffnorm 2> /dev/null
ffnorm() {
	# Use ffmpeg-normalize to normalize the audio of a video
	# https://superuser.com/questions/323119/how-can-i-normalize-audio-using-ffmpeg
	local input_file="$1"
	[ -z "$input_file" ] && echo "Usage:  ffnorm  filename" && return
	[ -f "$input_file" ] || echo "File not found: $input_file" && return
	echo -e "\n$input_file"

	local FFOPTS=" "
	FFOPTS+=" -c:a aac -b:a 192k"
	FFOPTS+=" --normalization-type peak --target-level 0 -f"
	FFOPTS+=" --output-folder ./Normalized"
	/usr/bin/ffmpeg-normalize $FFOPTS "$input_file"

}

#
# see HOW-TO_Install_Anaconda_3.txt
# usage:	cprep							## without an arugment, activates conda base environment
# 			conda activate pyspice			## activates PySpice environment
# 			conda deactivate				## deactivates the conda environment
#
# This command-line function prepares the bash environment for conda activation.
# The code in this function was originally inserted into .bashrc by the "conda init" command, but
# it should not be executed in every bash shell.
# The function name 'cprep' is short for "conda prepare"
unset -f cprep ; unalias cprep 2> /dev/null
cprep() {
	__conda_setup="$('/opt/anaconda3/bin/conda' 'shell.bash' 'hook' 2> /dev/null)"
	if [ $? -eq 0 ]; then
    	eval "$__conda_setup"
	else
    	if [ -f "/opt/anaconda3/etc/profile.d/conda.sh" ]; then
        	. "/opt/anaconda3/etc/profile.d/conda.sh"
    	else
        	export PATH="/opt/anaconda3/bin:$PATH"
    	fi
	fi
	unset __conda_setup
}
export -f cprep

unset -f reconnect ; unalias reconnect 2> /dev/null
reconnect() {
    # reconnect nordvpn to the same server
    local SERVER="$( nordvpn status | grep 'Hostname: ' | sed 's/^.*: \(.*\)\.nordvpn\.com/\1/' )"
    /usr/bin/nordvpn connect ${SERVER:-San_Francisco} || /usr/bin/nordvpn connect San_Francisco
    /usr/bin/nordvpn status
}

unset -f short ; unalias short 2> /dev/null
short () {
    # display a short version of a text file
    # by default, display the first 5 and the last 5 lines of a text file
    local -i NHEAD=5
    local -i NTAIL=5
    if [ $# != 1 ] ; then
        echo "Usage:  short  filename"
    else
        local -i KOUNT=$(wc -l $1 | cut -d' ' -f1)
        if (( $KOUNT - $NHEAD - $NTAIL < 3 )) ; then
            cat $1
        else
            head -5 $1
            echo -e " --- skipping $((KOUNT-10)) ---"
            tail -5 $1
        fi
    fi
}
export -f short

unset -f shorten ; unalias shorten 2> /dev/null
shorten() {
  # similar to the `short` function, but `shorten` reads stdin
  local USAGE="Usage: $0 [--head N] [--tail N]"

  # Function to parse command line options
  parse() {
    local OPTIONS=$(getopt -o h:t: --long head:,tail: -- "$@")
    if [ $? -ne 0 ]; then
      echo "${USAGE}"
      return 1
    fi

    eval set -- "$OPTIONS"

    while true; do
      case "$1" in
        --head) NHEAD=$2; shift 2 ;;
        --tail) NTAIL=$2; shift 2 ;;
        --) shift; break ;;
        *) echo -e "Unexpected option: $1\n${USAGE}"
           return 1 ;;
      esac
    done
  }

  
  # Function to push an item onto the stack
  push() {
      local item="$1"
      stack+=("$item")  # Add the item to the end of the array

      # Limit the size of the stack to 6 items (first 3 and last 3)
      if [ ${#stack[@]} -gt $NTOTAL ]; then
        # Remove the "middle" element (index NHEAD)
        CHARS=$((CHARS + $(echo -n "${stack[$NHEAD]}" | wc -c)))
        unset stack[$NHEAD]
        SKIPPED=$((SKIPPED+1))
        # Re-index the array to remove gaps
        stack=("${stack[@]}")
      fi
  }

  # Function to pop items from the stack
  pop() {
      if [ ${#stack[@]} -eq 0 ]; then
        echo "Stack is empty"
        return 3
      fi

      # Pop the first item
      echo -e "${stack[0]}"
      unset 'stack[0]'  # Remove the first item from the array
      stack=("${stack[@]}")
  }

  # Function to display current stack contents for debugging
  display_stack() {
      echo "Current Stack: ${stack[@]}"
  }

  #############  M A I N   E N T R Y  #############
  # Initialize an empty array to serve as the stack
  stack=()

  local -i NHEAD=3
  local -i NTAIL=3
  parse "$@" || return 4
  local -i NTOTAL=$((NHEAD+NTAIL))
  local -i SKIPPED=0
  local -i CHARS=0

  # Function to read lines from standard input and push them onto the stack
  while IFS= read -r line; do
    push "$line"
  done

  # Function to pop each item from the stack and send it to standard output
  while [ ${#stack[@]} -gt $NTAIL ]; do
    pop
  done

  echo "---------------- <skipped $SKIPPED lines, $CHARS characters> ----------------------"

  while [ ${#stack[@]} -gt 0 ]; do
    pop
  done

}
export -f shorten

unset -f duration ; unalias duration 2> /dev/null
duration () {
    local h m s
    local duration=$(ffmpeg -i "$1" 2>&1 | grep "Duration" | awk '{print $2}' | tr -d ',')
    IFS=: read h m s <<< "$duration"
    local total=$(echo "scale=2 ; $h * 60 + $m + $s / 60" | bc)
    echo "$total minutes"
}
export -f duration

unset -f npm ; unalias npm 2> /dev/null
npm() {
    # to grep executing npm without the -g argument
    # Check if any argument is -g
    if [[ " $* " == *" -g "* ]]; then
        # Execute /usr/bin/npm with all passed arguments
        /usr/bin/npm "$@"
    else
        echo "Error: The -g option is required to execute npm."
    fi
}
export -f npm

unset -f mount_chdir ; unalias mount_chdir 2> /dev/null
mount_chdir() {
  #
  # intended to mount a removable USB device and change directory
  # to the mounted directory.  the "chdir" means change dir
  #

  # check that there is exactly 1 argument
  if [[ $# == 1 ]] ; then
    local DEVICE="$1"
  else
    echo "$0: expected exactly 1 argument, e.g. /dev/sdh1"
    return 1
  fi

  # check that the device exists and is a block device
  if [[ -e $DEVICE ]] && lsblk -nd $DEVICE > /dev/null 2>&1 ; then
    true
  else
    echo "$0: device $DEVICE does not exist"
    return 2
  fi

  # check that the device is a partition
  # expect lsblk to output either disk, part or rom
  local DEVTYPE=$(lsblk -nd $DEVICE -o TYPE)
  case $DEVTYPE in
    part )
      ## echo "$0: Okay: device has type $DEVTYPE"
      ;;
    disk )
      echo "$0: device $DEVICE is a disk, not a partition"
      return 3
      ;;
    rom )
      echo "$0: device $DEVICE is a ROM device, CD/DVD perhaps"
      return 3
      ;;
    * )
      echo "$0: unrecognized device type for $DEVICE:  type is $DEVTYPE"
      return 3
      ;;
  esac

  # check that the device is not already mounted
  local MNTPT="$(lsblk -nd "$DEVICE" -o MOUNTPOINT)"
  if ! [[ -z "$MNTPT" ]] ; then
    echo "Already mounted: changing directory to $MNTPT"
    cd "$MNTPT"
    return 4
  fi

  # mount the device
  local MSG=$(udisksctl mount -b "$DEVICE")
  local RETVAL=$?

  # successful mount will give message with 4 fields
  # unsuccessful mount will give 1 field
  local NFIELDS=$(echo "$MSG" | awk '{print NF}')

  # 4th field, if it exists, will be the mount point
  case $NFIELDS in
    4) local MNTPT=$(echo "$MSG" | awk '{print $4}')
       if [[ -d $MNTPT ]] ; then
         # echo "mount point is $MNTPT"
         cd $MNTPT && pwd && return 0     # this is ideal, normal exit point
       else
         echo "$0: $MNTPT is not a directory:  this should not happen."
       fi
       return 5
       ;;
    *) echo "$MSG"
       echo "mount failed with return value $RETVAL"
       return 6
       ;;
  esac
  return 7    # this can't happen
}
export -f mount_chdir

unset -f lsrem ; unalias lsrem 2> /dev/null
lsrem() {
  # list the removable block devices by name, their type, and the current mountpoint, if any
  lsblk --raw -o RM,NAME,TYPE,MOUNTPOINT | \
    awk '$1==1 { printf "/dev/%-8s %-8s %-8s\n", $2, $3, $4 }'
}
export -f lsrem


unset -f lsrecent ; unalias lsrecent 2> /dev/null
lsrecent() {
  # read the systemd journal and look for the most recent entry having
  # the tag USB-ADDED.  this tag is used by /usr/local/sbin/usb-was-added.sh,
  # which is triggered by a udev rule when a usb device is plugged in.

  local TAG="USB-ADDED"

  # read the most recent tagged entry in the systemd journal
  ENTRY=$(journalctl -r -t "$TAG" -n 1 --output json)

  if [[ -n "$ENTRY" && "$ENTRY" != "-- No entries --" ]]; then
     # echo "$ENTRY"  # for debugging

     # print the message
     eval MSG=$(echo $ENTRY | jq .MESSAGE)
     echo $MSG

     # extract the device name.  expect e.g. /dev/sdx
     eval DEVNAME=$(echo $ENTRY | jq .USER_DEVNAME)

     # check whether block device still exists
     if [[ -b $DEVNAME ]] ; then
        echo
        # for any device, list the device size, etc
        lsblk -lpS -o NAME,SIZE,VENDOR,MODEL $DEVNAME

        # if there are any partitions
        if ls ${DEVNAME}?* 2>&1 > /dev/null ; then
           echo
           lsblk -lp  -o NAME,SIZE,LABEL,MOUNTPOINTS $DEVNAME?*
        else
           echo -e "\nNo partitions found on device $DEVNAME"
        fi
     else
        echo "$DEVNAME is now invalid: unplugged?"
     fi
  else 
     echo "No $TAG entry found in the systemd journal."
     return 1
  fi
  return $?
}
export -f lsrecent

unset -f hhmmss ; unalias hhmmss 2> /dev/null
hhmmss() {
  # convert between hh:mm:ss format and plain seconds
  # provide either format as the argument and get the other format
  input=$1
  if [[ -z $input ]]; then
    echo "Convert between HH:MM:SS and plain seconds."
    echo "  an argument in either one format or the other is required"
    return 1
  fi
  if [[ $input == *":"* ]]; then
    # Input has colon, convert hh:mm:ss to seconds
    seconds=$(date -d "1970-01-01 $input UTC" +%s)
    echo $seconds
  else
    # Input is seconds, convert to hh:mm:ss
    # Use -u to avoid timezone offset
    date -u -d "@$input" +%H:%M:%S
  fi
}
export hhmmss


unset -f mathematica ; unalias mathematica 2> /dev/null
mathematica() {
    local eth_ip="ozymanidas"
    local wifi_ip="ozymandias-wifi"
    local user="pi"
    local target_ip=""
    
    # Test ethernet first (timeout after 2 seconds)
    if ssh -o ConnectTimeout=2 -o BatchMode=yes "$user@$eth_ip" exit 2>/dev/null; then
        target_ip="$eth_ip"
        echo "Connecting via ethernet ($eth_ip)..."
    # Try wifi if ethernet fails
    elif ssh -o ConnectTimeout=2 -o BatchMode=yes "$user@$wifi_ip" exit 2>/dev/null; then
        target_ip="$wifi_ip"
        echo "Connecting via wifi ($wifi_ip)..."
    else
        echo "Error: Cannot reach RPi5 on either ethernet ($eth_ip) or wifi ($wifi_ip)" >&2
        return 1
    fi
    
    # Launch Mathematica on the reachable connection
    waypipe ssh "$user@$target_ip" /usr/bin/mathematica "$@"
}

